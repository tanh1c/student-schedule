{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@app/*": [
                "./src/app/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@contexts/*": [
                "./src/contexts/*"
            ],
            "@features/*": [
                "./src/features/*"
            ],
            "@hooks/*": [
                "./src/hooks/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ],
            "@lib/*": [
                "./src/lib/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ]
        }
    }
}
